#include <stdio.h>
#define MAX 10
#define INF 99999

int minKey(int key[], int mstSet[], int V)
{
    int min = INF, minIndex;

    for(int i = 0; i < V; i++)
    {
        if(mstSet[i] == 0 && key[i] < min)
        {
            min = key[i];
            minIndex = i;
        }
    }

    return minIndex;
}

void primMST(int graph[MAX][MAX], int V)
{
    int parent[MAX];
    int key[MAX];
    int mstSet[MAX];

    for(int i = 0; i < V; i++)
    {
        key[i] = INF;
        mstSet[i] = 0;
    }

    key[0] = 0;
    parent[0] = -1;

    for(int count = 0; count < V - 1; count++)
    {
        int u = minKey(key, mstSet, V);
        mstSet[u] = 1;

        for(int v = 0; v < V; v++)
        {
            if(graph[u][v] &&
               mstSet[v] == 0 &&
               graph[u][v] < key[v])
            {
                parent[v] = u;
                key[v] = graph[u][v];
            }
        }
    }

    int cost = 0;

    printf("\nEdges in MST:\n");
    printf("Edge\tWeight\n");

    for(int i = 1; i < V; i++)
    {
        printf("%d - %d\t%d\n",
               parent[i], i,
               graph[i][parent[i]]);

        cost += graph[i][parent[i]];
    }

    printf("\nMinimum Cost = %d\n", cost);
}

int main()
{
    int V;
    int graph[MAX][MAX];

    printf("Enter number of vertices: ");
    scanf("%d", &V);

    printf("Enter adjacency matrix:\n");

    for(int i = 0; i < V; i++)
    {
        for(int j = 0; j < V; j++)
        {
            scanf("%d", &graph[i][j]);
        }
    }

    primMST(graph, V);

    return 0;
}
